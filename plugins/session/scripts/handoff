#!/usr/bin/env bash
# handoff - Create a WIP commit with structured handoff context and push
# Exit codes: 0 success, 1 bad usage, 2 not a git repo, 3 nothing to commit, 4 push failed

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
    cat <<'EOF'
Usage: handoff -m MESSAGE [--issue-comment COMMENT]

Creates a WIP commit with structured handoff context and pushes it
for cross-machine transfer.

The MESSAGE (goes into git commit body) should contain:

  === IN PROGRESS ===
  <current state of work, files touched>

The COMMENT (posted to the linked issue if branch matches type/NNN-*) should contain:

  === HANDOFF ===
  ...

  === NEXT STEPS ===
  <what to pick up next>

  === KEY CONTEXT ===
  <decisions, gotchas, important state>

Options:
  -m MESSAGE             WIP commit body (required)
  --issue-comment TEXT   Comment to post on linked issue (optional)
  -h, --help             Show this help
EOF
    exit 1
}

message=""
issue_comment=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage ;;
        -m)
            [[ $# -lt 2 ]] && { echo "Error: -m requires a message" >&2; exit 1; }
            message="$2"
            shift 2
            ;;
        --issue-comment)
            [[ $# -lt 2 ]] && { echo "Error: --issue-comment requires a value" >&2; exit 1; }
            issue_comment="$2"
            shift 2
            ;;
        *)
            echo "Error: unexpected argument '$1'" >&2
            usage
            ;;
    esac
done

if [[ -z "$message" ]]; then
    echo "Error: -m MESSAGE is required" >&2
    usage
fi

# Check we're in a git repo
if ! git rev-parse --git-dir &>/dev/null; then
    echo "Error: not a git repository" >&2
    exit 2
fi

# Stage everything
git add -A

# Check there's something to commit
if git diff --cached --quiet; then
    echo "Error: nothing to commit (working tree clean)" >&2
    exit 3
fi

# Build commit message
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
hostname=$(hostname -s 2>/dev/null || echo "unknown")

# Extract first line for subject, truncate to 72 chars
first_line=$(echo "$message" | head -1)
if [[ ${#first_line} -gt 65 ]]; then
    first_line="${first_line:0:62}..."
fi

# List staged files
staged_files=$(git diff --cached --name-only)

commit_body="WIP: ${first_line}

=== HANDOFF ===
Branch: ${branch}
Timestamp: ${timestamp}
From: ${hostname}

${message}

=== FILES IN THIS COMMIT ===
${staged_files}"

# Commit
git commit -m "$commit_body" --no-verify

echo "Committed WIP handoff on branch '$branch'"

# Push
if git push 2>&1; then
    echo "Pushed to remote."
else
    echo "Warning: push failed — commit exists locally." >&2
    echo "Push manually with: git push" >&2
    exit 4
fi

# Post issue comment if branch matches type/NNN-* and comment provided
if [[ -n "$issue_comment" && "$branch" =~ ^[a-z]+/([0-9]+)- ]]; then
    issue_number="${BASH_REMATCH[1]}"
    tmp_comment=$(mktemp /tmp/handoff-comment.XXXXXX.md)
    echo "$issue_comment" > "$tmp_comment"
    if bash "${SCRIPT_DIR}/git-cli" issue comment "$issue_number" --body-file "$tmp_comment" 2>&1; then
        echo "Posted handoff context to issue #${issue_number}."
    else
        echo "Warning: failed to post comment to issue #${issue_number}." >&2
    fi
    rm -f "$tmp_comment"
fi

echo ""
echo "Resume on another machine with: git pull && /session:resume"
